.coverage
htmlcov/
.tox/
.mypy_cache/
.ruff_cache/
.dmypy.json
dmypy.json

# Логи и БД
*.log
*.sqlite
*.sqlite3
*.db

# Файлы конфигурации с секретами
.env
.env.*
!.env.example

# Результаты сборки
/build/
/dist/
*.egg-info/
*.egg
.eggs/

# IDEs и редакторы
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

